height = int(input("Enter height: "))

for i in range(1, height + 1):
    print("*" * i)




size = int(input("Enter size: "))
char = input("Enter character: ")

for i in range(size):
    print(char * size)





width = int(input("Enter odd width: "))

for i in range(1, width + 1, 2):
    spaces = (width - i) // 2
    print(" " * spaces + "*" * i)

for i in range(width - 2, 0, -2):
    spaces = (width - i) // 2
    print(" " * spaces + "*" * i)
